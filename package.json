{
  "name": "com.itacolomysma.app",
  "displayName": "Comando App",
  "version": "1.0.5",
  "description": "Comando App - Gestao de Mensagens (Angular + Cordova)",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ecosystem:cordova"
  ],
  "author": "Comando Auto Pecas",
  "license": "Apache-2.0",
  "cordova": {
    "platforms": [
      "android",
      "ios"
    ],
    "plugins": {
      "cordova-plugin-cache-clear": {},
      "at.modalog.cordova.plugin.cache": {},
      "cordova-plugin-firebasex": {},
      "cordova-plugin-fingerprint-aio": {
        "FACEID_USAGE_DESCRIPTION": "Use Face ID para login rápido e seguro"
      },
      "cordova-plugin-secure-storage-echo": {},
      "cordova-plugin-x-socialsharing": {},
      "cordova-plugin-file": {
        "ANDROIDX_WEBKIT_VERSION": "1.4.0"
      },
      "cordova-plugin-file-opener2": {
        "ANDROIDX_WEBKIT_VERSION": "1.4.0"
      }
    }
  },
  "devDependencies": {
    "cordova-android": "^14.0.1",
    "cordova-ios": "^8.1.0",
    "cordova-plugin-cache": "github:moderna/cordova-plugin-cache",
    "cordova-plugin-cache-clear": "^1.3.8",
    "cordova-plugin-file": "^8.1.3",
    "cordova-plugin-file-opener2": "^4.0.0",
    "cordova-plugin-fingerprint-aio": "^6.0.1",
    "cordova-plugin-secure-storage-echo": "^5.1.1",
    "cordova-plugin-x-socialsharing": "^6.0.4",
    "es6-promise-plugin": "^4.2.2",
    "npm": "^11.11.1"
  },
  "dependencies": {
    "@awesome-cordova-plugins/secure-storage-echo": "^8.1.0",
    "cordova-plugin-firebasex": "19.0.1"
  }
}
